      "event": [
        {
          "listen": "test",
          "script": {
            "type": "text/javascript",
            "exec": [
              "pm.test('register status is 201', function () {",
              "    pm.response.to.have.status(201);",
              "});",
              "",
              "const data = pm.response.json();",
              "if (data.access_token) {",
              "    pm.collectionVariables.set('token', data.access_token);",
              "}"
            ]
          }
        }
